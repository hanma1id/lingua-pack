    { "section": "주문", "foreign": "これをください。",          "pronIpa": "/koɾe o kɯdasai/",     "pronKo": "**코**레오 쿠**다**사이", "korean": "이걸로 주세요.",       "english": "This one, please.", "context": "메뉴 가리키며" },
    { "section": "주문", "foreign": "おすすめは何ですか？",       "pronIpa": "/osɯsɯme wa naɴ desɯ ka/","pronKo": "오**스**스메와 **난**데스까?","korean": "추천은 뭐예요?",     "english": "What do you recommend?", "context": "" },
    { "section": "주문", "foreign": "ラーメンを一つ。",          "pronIpa": "/ɾaːmeɴ o hitotsɯ/",    "pronKo": "**라**-멩오 히**또**츠",  "korean": "라멘 하나요.",         "english": "One ramen.", "context": "" },
    { "section": "주문", "foreign": "同じものを。",              "pronIpa": "/onadʑi mono o/",       "pronKo": "오**나**지 **모**노오",   "korean": "같은 걸로.",           "english": "The same, please.", "context": "" },
    { "section": "주문", "foreign": "セットにします。",          "pronIpa": "/setto ni ɕimasɯ/",    "pronKo": "**셋**또니 시**마**스",   "korean": "세트로 할게요.",       "english": "I'll take the set.", "context": "" },

    { "section": "요청·수정", "foreign": "辛くしないでください。","pronIpa": "/kaɾakɯ ɕinaide kɯdasai/","pronKo": "카**라**꾸 시**나**이데 쿠**다**사이","korean": "맵지 않게 해주세요.","english": "Not spicy, please.", "context": "" },
    { "section": "요청·수정", "foreign": "アレルギーがあります。","pronIpa": "/aɾeɾɡiː ɡa aɾimasɯ/",  "pronKo": "아**레**루기-가 **아**리마스","korean": "알러지 있어요.",  "english": "I have an allergy.", "context": "" },
    { "section": "요청·수정", "foreign": "お水をください。",      "pronIpa": "/omidzɯ o kɯdasai/",    "pronKo": "오**미**즈오 쿠**다**사이","korean": "물 주세요.",           "english": "Water, please.", "context": "" },
    { "section": "요청·수정", "foreign": "少し待ってください。",   "pronIpa": "/sɯkoɕi matte kɯdasai/","pronKo": "스**꼬**시 **맛**떼 쿠**다**사이","korean": "잠시만 기다려주세요.","english": "Please wait a moment.", "context": "" },
